{
  "format": "memstead-plugin/v0",
  "vaults": [
    "project_vaults/engine",
    "project_vaults/plugin",
    "exec_vaults/example-plan"
  ],
  "mutations": {
    "require_notes": true
  },
  "vault_management": {
    "create": [
      { "pattern": "exec-*", "schemas": ["default@1.0.0"] },
      { "pattern": "planning/plan-*", "schemas": ["default@1.0.0"] }
    ],
    "delete": [
      { "pattern": "exec-*" },
      { "pattern": "planning/plan-*" }
    ]
  },
  "plugin": {
    "claude_code": {
      "outer_vcs": {
        "enabled": true
      }
    }
  }
}
