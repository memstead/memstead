{
  "format": "memstead-plugin/v0",
  "mems": [
    "project_mems/engine",
    "project_mems/plugin",
    "exec_mems/example-plan"
  ],
  "mutations": {
    "require_notes": true
  },
  "mem_management": {
    "create": [
      { "pattern": "exec-*", "schemas": ["default@1.0.0"] },
      { "pattern": "planning/plan-*", "schemas": ["default@1.0.0"] }
    ],
    "delete": [
      { "pattern": "exec-*" },
      { "pattern": "planning/plan-*" }
    ]
  },
  "plugin": {
    "claude_code": {
      "outer_vcs": {
        "enabled": true
      }
    }
  }
}
