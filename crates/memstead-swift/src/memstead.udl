// UniFFI interface for the macOS app.
//
// Read-only surface: input records (VaultInit, HealthOptions, SearchScope),
// response records (Entity, Stats, HealthSummary, List/Search/Relations/
// Cluster/Path results), the error enum, and the Engine interface with
// method signatures. Mutation FFI is deferred — kept as a UniFFI
// `interface` (not a dictionary) so mutation methods can land later
// without breaking the existing bindings.

namespace memstead {
    string version();

    // Enumerate the workspace's vaults by walking the `vault-repo/.git/`
    // branch list (excluding `main` and registry refs), one `VaultInit`
    // per vault. The Swift app calls this before constructing the Engine
    // to seed its UI; the Engine itself loads its mounts from
    // `.memstead/state/mounts.json` and does not consume this list.
    sequence<VaultInit> discover_vaults(string project_root);

    // Construct an engine rooted at an explicit `workspace_root` (a directory
    // containing `.memstead/workspace.toml`). Cwd-independent — unlike the
    // `Engine(vaults:)` constructor, which falls back to the process cwd.
    // Backend-agnostic: folder and git-branch mounts open through this one
    // call with no caller-side branching. Throws a typed, actionable error
    // when the path has no recognised workspace layout.
    [Throws=MemsteadError]
    Engine engine_open(string workspace_root);

    // Initialise a brand-new filesystem (folder-backed) vault at `root` — the
    // engine-owned bootstrap the macOS app routes through instead of writing
    // `.memstead/config.json` itself. Writes the seed config + adapter marker +
    // one-folder-mount roster, so the result roots through `engine_open`. The
    // vault root is the workspace root (collapsed single-vault form).
    [Throws=MemsteadError]
    void init_filesystem_vault(string root, string name, string schema);
};

// ---------------------------------------------------------------------------
// Error — surfaced as a throwing Swift API.
//
// Maps memstead_base::EngineError onto a smaller Swift-facing set. Most
// validation kinds collapse into `ValidationFailed { message }`; the two
// cases the macOS app actually branches on (`UnknownSection`,
// `UnknownVault`) get their own variants carrying the declared lists and
// a suggestion so the UI can render a picker without re-parsing messages.
// ---------------------------------------------------------------------------

[Error]
interface MemsteadError {
    NotFound(string message);
    ValidationFailed(string message);
    HashMismatch(string message, string current);
    SchemaError(string message);
    IoError(string message);
    Internal(string message);
    UnknownSection(string key, string entity_type, sequence<string> declared, string? suggestion);
    UnknownVault(string name, sequence<string> writable_vaults);
};

// ---------------------------------------------------------------------------
// Input records — Engine bootstrap + query options.
// ---------------------------------------------------------------------------

dictionary VaultInit {
    string name;
    string dir;
    string schema_name;
    string schema_version;
};

dictionary HealthOptions {
    u32 most_connected_limit = 10;
};

// Flat query shape — mirrors `memstead_base::ops::Query`. All fields optional
// so callers can pass a partial predicate; an empty Query (or `None`) makes
// `search` behave as a metadata-only filter.
dictionary Query {
    sequence<string> any_of;
    sequence<string> not_in;
    string? phrase;
    string? field;
};

dictionary SearchScope {
    Query? query;
    string? vault;
    string? entity_type;
    u32? limit;
    u32? offset;
    record<DOMString, string> filters;
    record<DOMString, string> range_filters;
    string? edge_type;
    string? related_to;
    u32? depth;
    boolean? stub;
    sequence<string>? expand_via;
    u32? expand_depth;
};

// ---------------------------------------------------------------------------
// Entity records. MetadataValue mirrors the engine's four variants; metadata
// is a flat sequence of (key, value) pairs to preserve insertion order
// across the FFI (UniFFI maps don't guarantee ordering).
// ---------------------------------------------------------------------------

[Enum]
interface MetadataValue {
    BoolValue(boolean value);
    IntValue(i64 value);
    FloatValue(double value);
    StringValue(string value);
};

dictionary MetadataEntry {
    string key;
    MetadataValue value;
};

dictionary Section {
    string key;
    string content;
};

dictionary Relationship {
    string rel_type;
    string target;
    string? description;
};

dictionary Entity {
    string id;
    string title;
    string entity_type;
    string vault;
    string file_path;
    sequence<MetadataEntry> metadata;
    sequence<Section> sections;
    sequence<Relationship> relationships;
    string content_hash;
    boolean stub;
};

// ---------------------------------------------------------------------------
// Stats. edge_types is a flat sequence rather than a map for Identifiable
// SwiftUI list rendering and stable sort on the Swift side.
// ---------------------------------------------------------------------------

dictionary EdgeTypeCount {
    string rel_type;
    u64 count;
};

// `stub_count` (and therefore `real_count = entity_count - stub_count`) is a
// UI staple the MCP surface also exposes (as top-level fields on
// `memstead_health`'s default response); carrying it on Stats avoids a second
// `get_health()` round-trip just to display the entity/stub split.
//
// `writable_vaults` + `read_vaults` mirror the same fields on
// `memstead_health`'s default response so the macOS app can render the vault
// list from one call (write vaults come from the router; read vaults are
// the visible set minus the writable set).
dictionary Stats {
    u64 entity_count;
    u64 stub_count;
    u64 edge_count;
    sequence<EdgeTypeCount> edge_types;
    u64 community_count;
    u64 vault_count;
    sequence<string> types_in_use;
    sequence<string> writable_vaults;
    sequence<string> read_vaults;
};

// ---------------------------------------------------------------------------
// Health.
// ---------------------------------------------------------------------------

dictionary HealthIssue {
    string field;
    string message;
};

dictionary MissingField {
    string id;
    string title;
    f32 score;
    sequence<HealthIssue> issues;
};

dictionary StaleEntity {
    string id;
    string title;
    u64 days_since_modified;
};

dictionary HealthSummary {
    sequence<StaleEntity> stale_entities;
    sequence<MissingField> missing_fields;
    u64 orphan_count;
    u64 stub_count;
};

// ---------------------------------------------------------------------------
// List / search.
// ---------------------------------------------------------------------------

dictionary SearchHit {
    string id;
    string title;
    string vault;
    string entity_type;
    boolean stub;
    f32 score;
    u64 tokens;
    string? snippet;
    sequence<Section> sections;
};

dictionary SearchResult {
    u64 total;
    u64 returned;
    u64 offset;
    sequence<SearchHit> hits;
    sequence<string> warnings;
};

dictionary ListResult {
    u64 total;
    u64 returned;
    u64 offset;
    u64 total_tokens;
    sequence<SearchHit> hits;
    sequence<string> warnings;
};

// ---------------------------------------------------------------------------
// Relations — Session-2a-new type. Composes the store's outgoing + incoming
// edge views for one entity into one record, matching what GraphDataStore
// currently stitches together from multiple MCP calls.
// ---------------------------------------------------------------------------

enum RelationDirection {
    "Outgoing",
    "Incoming",
};

enum EdgeSource {
    "Explicit",
    "Hierarchy",
    "BodyLink",
};

dictionary RelationEdge {
    string rel_type;
    string other_id;
    string other_title;
    string other_entity_type;
    RelationDirection direction;
    EdgeSource source;
};

dictionary Relations {
    string entity_id;
    sequence<RelationEdge> outgoing;
    sequence<RelationEdge> incoming;
};

// ---------------------------------------------------------------------------
// Communities.
// ---------------------------------------------------------------------------

dictionary ClusterInfo {
    string id;
    sequence<string> entities;
};

// ---------------------------------------------------------------------------
// Reload diff.
// ---------------------------------------------------------------------------

dictionary ReloadResult {
    sequence<string> added;
    sequence<string> changed;
    sequence<string> removed;
};

// ---------------------------------------------------------------------------
// Per-vault commit-delta + agent-notes feed. Mirrors the MCP /
// `memstead-cli` surface (`memstead_changes_since`, `memstead changes` —
// `--include-notes` for the notes branch, `memstead_health.vaults[].vcs.head`
// for the per-vault head) so the macOS app has parity with what the
// Claude Code plugin and operator CLI consume.
// ---------------------------------------------------------------------------

[Enum]
interface ChangeEnvelope {
    Added(string id, string? title, string? entity_type);
    Updated(string id, string? title, string? entity_type);
    Removed(string id, string? title, string? entity_type);
    Renamed(string from_id, string to_id, string? title, string? entity_type);
};

dictionary CommitNote {
    string vault;
    string sha;
    string subject;
    string? tool_verb;
    string? entity_id;
    string? note;
    string? actor;
    string? tool;
    string? client;
    i64 timestamp;
};

dictionary ChangesReport {
    string vault;
    string since;
    string head;
    sequence<ChangeEnvelope> changes;
};

dictionary AgentNotesReport {
    string vault;
    string since;
    string head;
    sequence<CommitNote> notes;
    // SHA of `refs/heads/__MEMSTEAD` — unified schemas + per-vault
    // configs branch. `None` when the workspace has not been
    // migrated to the unified layout yet.
    string? memstead_ref;
};

dictionary ParseRecoveryEntry {
    string entity_id;
    string rel_type;
    string target;
    // "removed" (recovered), "skipped" (read-only origin), or "failed".
    string outcome;
    // Skip reason or the underlying engine error code; `None` for
    // "removed" entries.
    string? reason;
};

dictionary ParseRecoveryReport {
    sequence<ParseRecoveryEntry> entries;
    // SHA of the last per-source re-render commit; `None` when the
    // workspace was already clean (nothing rewritten).
    string? commit_sha;
};

// ---------------------------------------------------------------------------
// Vault lifecycle — create / delete / set-schema / set-version through the
// engine. Mirrors the `memstead_vault_*` MCP contract onto the in-process
// binding so the macOS roster manages vaults without any vault-repo mutation
// (git ops, raw `config.json`/`.md` writes, `.git` introspection) originating
// in Swift. Export-as-`.mem` is a separate, different-shaped task — not here.
// ---------------------------------------------------------------------------

dictionary VaultCreateRequest {
    string name;
    string location;
    string schema;
    string? vcs_gitdir;
    string? vcs_worktree;
    string? note;
    boolean operator_mode;
};

dictionary VaultCreateOutcome {
    string name;
    string location;
    string schema_ref;
    string seed_commit_sha;
    sequence<string> warnings;
};

dictionary VaultDeleteOutcome {
    string name;
    boolean deleted_from_router;
    boolean files_deleted;
    sequence<string> warnings;
};

dictionary VaultSchemaOutcome {
    string vault;
    string schema_pin;
    string? migration_target;
    string outcome;
    sequence<string> findings;
};

dictionary VaultVersionOutcome {
    string vault;
    string? old_version;
    string new_version;
    sequence<string> warnings;
};

enum VaultBackendKind {
    "GitBranch",
    "Folder",
    "Archive",
    "InMemory",
};

dictionary VaultRosterEntry {
    string vault;
    VaultBackendKind backend;
    boolean writable;
    string? schema_pin;
    u64 entity_count;
    boolean drifted;
};

dictionary DanglingCrossVaultEdge {
    string entity_path;
    string target_id;
    string target_vault;
};

dictionary VaultExportOutcome {
    string archive_path;
    string name;
    string version;
    u64 entity_count;
    u64 size_bytes;
    sequence<DanglingCrossVaultEdge> dangling_cross_vault_edges;
};

// ---------------------------------------------------------------------------
// Engine interface. Read/query/sync operations plus the first
// disk-mutating method, `apply_parse_recovery` (parity with `memstead
// recover`). Kept as a UniFFI `interface` (not a dictionary) so further
// mutation methods can land without breaking the existing bindings.
// ---------------------------------------------------------------------------

interface Engine {
    [Throws=MemsteadError]
    constructor(sequence<VaultInit> vaults);

    Stats get_stats();
    HealthSummary get_health(HealthOptions options);
    ListResult list_entities(SearchScope scope);
    SearchResult search(SearchScope scope);
    Entity? get_entity(string id);

    [Throws=MemsteadError]
    Relations get_relations(string id);

    sequence<ClusterInfo> get_overview(boolean rebuild);

    // The workspace vault roster — one entry per mounted vault, with the
    // per-mount facts (backend kind, capability, schema pin, entity count,
    // drift) the home sidebar renders. Every fact comes from the engine,
    // so the roster never reconstructs backend/capability from a Swift-side
    // read of `mounts.json`. Cannot fail (per-vault drift probes that error
    // collapse to `false`).
    sequence<VaultRosterEntry> vault_roster();

    [Throws=MemsteadError]
    ReloadResult reload();

    // Cached branch-tip SHA for a writable vault. `None` for fresh
    // vaults with no commits yet — consumers substitute the canonical
    // empty-tree sentinel `4b825dc642cb6eb9a060e54bf8d69288fbee4904`.
    [Throws=MemsteadError]
    string? vault_head_sha(string vault);

    // Two-tree diff between `since` and the vault's current HEAD. See
    // `memstead_changes_since` for semantics. `rename_similarity` mirrors
    // the MCP knob (default 0.6 when `None`).
    [Throws=MemsteadError]
    ChangesReport changes_since(string vault, string since, f32? rename_similarity);

    // Walk per-commit agent-notes between `since` and HEAD. See the
    // engine's `Engine::agent_notes`. The response also carries the
    // workspace-level `__MEMSTEAD` ref tip (unified schemas + per-vault
    // configs).
    [Throws=MemsteadError]
    AgentNotesReport agent_notes(string vault, string since);

    // Bulk-fix accumulated parse-time relation drift across every
    // writable vault — the UniFFI counterpart to `memstead recover`.
    // First disk-mutating UniFFI method; provenance mirrors the CLI's
    // `Actor::Cli`. `note` lands on each per-source re-render commit.
    [Throws=MemsteadError]
    ParseRecoveryReport apply_parse_recovery(string? note);

    // Four-primitive pipeline edits (medium / facet / projection). The
    // macOS pipeline editor routes here instead of hand-writing `.memstead/`
    // JSON. Create/update carry the primitive as a JSON string (Facet's
    // free-form `engagement` field rules out a typed record); delete/rename
    // take identifiers. Referential integrity and snapshot refresh live in
    // the engine. See `memstead_base::pipeline_edit`.
    [Throws=MemsteadError]
    void add_medium(string vault, string name, string medium_json);
    [Throws=MemsteadError]
    void update_medium(string vault, string name, string medium_json);
    [Throws=MemsteadError]
    void delete_medium(string vault, string name);
    [Throws=MemsteadError]
    void rename_medium(string vault, string old_name, string new_name);

    [Throws=MemsteadError]
    void add_facet(string vault, string name, string facet_json);
    [Throws=MemsteadError]
    void update_facet(string vault, string name, string facet_json);
    [Throws=MemsteadError]
    void delete_facet(string vault, string name);
    [Throws=MemsteadError]
    void rename_facet(string vault, string old_name, string new_name);

    [Throws=MemsteadError]
    void add_projection(string vault, string name, string projection_json);
    [Throws=MemsteadError]
    void update_projection(string vault, string name, string projection_json);
    [Throws=MemsteadError]
    void delete_projection(string vault, string name);
    [Throws=MemsteadError]
    void rename_projection(string vault, string old_name, string new_name);

    // Ingests are flat (workspace-level, not vault-scoped) — no vault param.
    [Throws=MemsteadError]
    void add_ingest(string name, string ingest_json);
    [Throws=MemsteadError]
    void update_ingest(string name, string ingest_json);
    [Throws=MemsteadError]
    void delete_ingest(string name);
    [Throws=MemsteadError]
    void rename_ingest(string old_name, string new_name);

    // Read the four-primitive store as JSON (the edit methods' read
    // counterpart). The macOS pipeline editor deserializes this to display
    // mediums/facets/projections/ingests. Cannot fail.
    string pipeline_configs_json();

    // Vault lifecycle. The macOS roster routes create/delete/set-schema/
    // set-version here instead of mutating the vault-repo from Swift; the
    // engine owns backend instantiation, allowlist gating, policy scrub,
    // and the seed/version commits. See `memstead_engine::vault_management`
    // and `memstead_base::Engine::{set_vault_schema, set_vault_version}`.
    [Throws=MemsteadError]
    VaultCreateOutcome create_vault(VaultCreateRequest request);
    [Throws=MemsteadError]
    VaultDeleteOutcome delete_vault(string name, string? note, boolean operator_mode);
    [Throws=MemsteadError]
    VaultSchemaOutcome set_vault_schema(string vault, string schema);
    [Throws=MemsteadError]
    VaultVersionOutcome set_vault_version(string vault, string version, string? note);

    // Export a vault as a portable `.mem` archive at `output_path`.
    // Backend-symmetric (folder snapshot / git-branch history); archive
    // mounts refuse (sealed), in-memory mounts refuse (unsupported). The
    // engine owns the export — Swift never walks the vault directory. See
    // `memstead_base::Engine::export_vault`.
    [Throws=MemsteadError]
    VaultExportOutcome export_vault(string vault, string output_path);
};
