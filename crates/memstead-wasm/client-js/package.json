{
  "name": "@memstead/client",
  "version": "0.1.0",
  "description": "Browser client wrapping @memstead/wasm + the memstead-bridge HTTP/SSE surface as a single MemSyncClient class.",
  "license": "(MIT OR Apache-2.0)",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "peerDependencies": {
    "@memstead/wasm": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@memstead/wasm": {
      "optional": true,
      "_note": "Optional and truthfully so: the TS surface only references the WasmEngineLike interface (src/types.ts) — consumers inject the engine via `engineFactory`, typically but not necessarily from @memstead/wasm. Optional also keeps local `npm install` green until @memstead/wasm is live on the registry."
    }
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "memstead",
    "knowledge-graph",
    "browser",
    "wasm",
    "client"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/memstead/memstead",
    "directory": "crates/memstead-wasm/client-js"
  },
  "homepage": "https://memstead.io",
  "publishConfig": {
    "access": "public"
  }
}
