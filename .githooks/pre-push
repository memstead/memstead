#!/bin/sh
# Pre-push gate: refuse pushes whose commits change an API surface without
# the regenerated docs reference committed alongside.
#
# Why local enforcement: the docs-drift.yml CI check runs *after* a direct
# push to main and can never block it — on 2026-07-07/08 it fired red on
# five consecutive pushes and nobody noticed. This hook applies the
# project's own thesis to its own build: refuse at the boundary instead of
# flagging later. CI stays as the backstop for pushes from other clones.
#
# Wiring (once per clone): git config core.hooksPath .githooks
# Escape hatch (emergencies only): MEMSTEAD_SKIP_DOCS_DRIFT=1 git push …

set -eu

if [ "${MEMSTEAD_SKIP_DOCS_DRIFT:-0}" = "1" ]; then
  echo "pre-push: docs-drift gate skipped via MEMSTEAD_SKIP_DOCS_DRIFT=1" >&2
  exit 0
fi

REFERENCE_DIR="docs-site/src/content/docs/reference"
ZERO="0000000000000000000000000000000000000000"

touches_surface=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
  [ "$local_sha" = "$ZERO" ] && continue # branch deletion — nothing to check
  if [ "$remote_sha" = "$ZERO" ]; then
    range="$local_sha" # new branch: check the pushed tip's tree state below
    touches_surface=1
    break
  fi
  if git diff --name-only "$remote_sha".."$local_sha" -- \
      crates/ xtask/ "$REFERENCE_DIR" | grep -q .; then
    touches_surface=1
    break
  fi
done

[ "$touches_surface" = "0" ] && exit 0

echo "pre-push: surface paths changed — verifying the docs reference is regenerated…" >&2
cargo run -q -p xtask -- generate-docs --output "$REFERENCE_DIR"

if ! git diff --exit-code --stat -- "$REFERENCE_DIR" >&2; then
  cat >&2 <<'MSG'

pre-push: REFUSED — the committed docs reference is stale for this push.
The regenerated files are now in your working tree. Fix:

    git add docs-site/src/content/docs/reference
    git commit -m "docs: regenerate API reference"
    git push

(Emergency bypass: MEMSTEAD_SKIP_DOCS_DRIFT=1 git push — CI will still flag it.)
MSG
  exit 1
fi

exit 0
